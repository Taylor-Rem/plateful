APP_NAME=Plateful
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.laravel.cloud

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

# Use stderr in production so Laravel Cloud captures logs
LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# Error monitoring (Sentry). Leave DSN blank locally/in tests so Sentry is a
# no-op and sends no events. Set SENTRY_LARAVEL_DSN in Laravel Cloud from the
# Sentry project dashboard to enable reporting in production.
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Database (Laravel Cloud auto-injects these for the attached Postgres database)
DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# Sessions / cache / queue
# On Laravel Cloud Starter (no Redis): use database driver for sessions/cache/queue.
# On Growth+ (with KV/Redis): use redis.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Leave null so cookies stay scoped to each tenant host (admin.X, marcos.X, etc.).
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Restaurant media (logos, menu/hero/about images, gallery photos) follow the
# default filesystem disk unless MEDIA_DISK is set. On Laravel Cloud, leave
# MEDIA_DISK unset so media uses the injected default bucket (must be public).
# Locally, set MEDIA_DISK=public so Storage::url() resolves via the storage:link.
MEDIA_DISK=public

CACHE_STORE=database
# CACHE_PREFIX=

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail — Resend
MAIL_MAILER=resend
MAIL_FROM_ADDRESS="hello@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"
RESEND_API_KEY=

# Object storage (S3-compatible). On Laravel Cloud these are auto-injected for the
# attached bucket, which is also set as the default disk — so media uses it with
# no extra config. Only set these manually for a self-managed S3 bucket.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Platform / tenancy
PLATFORM_PRIMARY_DOMAIN=your-app.laravel.cloud
PLATFORM_ADMIN_SUBDOMAIN=admin

# Stripe Connect (use test-mode keys locally)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_COUNTRY=US

# Square POS injection (OAuth). Sandbox Application ID/Secret from the app's
# OAuth tab at developer.squareup.com. SQUARE_ENVIRONMENT is `sandbox` or
# `production`. The redirect URI must match the one registered on the Square
# app EXACTLY and resolve on the admin host, e.g.
# https://admin.plateful.test/pos/square/callback (local) or
# https://admin.plateful.fyi/pos/square/callback (prod).
SQUARE_APPLICATION_ID=
SQUARE_APPLICATION_SECRET=
SQUARE_ENVIRONMENT=sandbox
SQUARE_REDIRECT_URI=

# Clover POS injection (v2/OAuth, expiring tokens). App ID/Secret from the
# app's "App Settings" at sandbox.dev.clover.com (sandbox) / clover.com (prod).
# Enable the Orders (R/W), Merchants (R), and Inventory (R) app permissions —
# Clover has no scope parameter; permissions are set on the app. CLOVER_ENVIRONMENT
# is `sandbox` or `production`. The redirect URI must match the one registered on
# the Clover app EXACTLY and resolve on the admin host, e.g.
# https://admin.plateful.test/pos/clover/callback (local) or
# https://admin.plateful.fyi/pos/clover/callback (prod).
CLOVER_APP_ID=
CLOVER_APP_SECRET=
CLOVER_ENVIRONMENT=sandbox
CLOVER_REDIRECT_URI=

# Uber Direct delivery dispatch. Credentials are PER-RESTAURANT — each
# restaurant holds its own Uber Direct account (Uber bills them directly) and
# pastes their Client ID / Secret / Customer ID into the admin, which stores
# them encrypted in `delivery_integrations`. Production reads ONLY from there.
#
# The keys below are sandbox credentials for local development and the opt-in
# UberDirectLiveSandboxTest — they are never a production fallback. Get them at
# direct.uber.com -> Management -> Developer; a test sandbox is provisioned
# automatically and test credentials create no real deliveries.
#
# There is no environment/host setting: Uber Direct serves test and production
# from the same host (api.uber.com) and the credentials decide which you're in.
UBER_DIRECT_SANDBOX_CLIENT_ID=
UBER_DIRECT_SANDBOX_CLIENT_SECRET=
UBER_DIRECT_SANDBOX_CUSTOMER_ID=

# Google OAuth ("Sign in with Google"). The redirect URI must match the one
# registered on the Google OAuth client and must live on the platform host.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Google Places autocomplete for delivery addresses. Same Google Cloud project
# as the OAuth client above, but a separate credential: an API key, not an OAuth
# client. Enable the "Places API" on the project, then create the key under
# APIs & Services -> Credentials -> Create credentials -> API key.
#
# Restrict it by IP ADDRESS (your server), NOT by HTTP referrer, and restrict it
# to the Places API. It is used server-side only — we proxy Places through the
# backend so the key never reaches a browser and so custom domains don't each
# need adding to a referrer allowlist.
GOOGLE_MAPS_API_KEY=

VITE_APP_NAME="${APP_NAME}"

CLAUDE_API_KEY=
