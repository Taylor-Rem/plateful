APP_NAME=Plateful
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.laravel.cloud

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

# Use stderr in production so Laravel Cloud captures logs
LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# Database (Laravel Cloud auto-injects these for the attached Postgres database)
DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# Sessions / cache / queue
# On Laravel Cloud Starter (no Redis): use database driver for sessions/cache/queue.
# On Growth+ (with KV/Redis): use redis.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Leave null so cookies stay scoped to each tenant host (admin.X, marcos.X, etc.).
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail — Resend
MAIL_MAILER=resend
MAIL_FROM_ADDRESS="hello@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"
RESEND_API_KEY=

# Restaurant assets — point at Laravel Cloud's bundled object storage (S3-compatible).
# Cloud auto-injects AWS_* style env vars; the disk falls back to them when the
# RESTAURANT_ASSETS_* equivalents are not set.
FILESYSTEM_RESTAURANT_ASSETS_DRIVER=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Platform / tenancy
PLATFORM_PRIMARY_DOMAIN=your-app.laravel.cloud
PLATFORM_ADMIN_SUBDOMAIN=admin

VITE_APP_NAME="${APP_NAME}"
